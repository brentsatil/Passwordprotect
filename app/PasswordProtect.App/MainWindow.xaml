<Window x:Class="PasswordProtect.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasswordProtect" Height="520" Width="640"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Protect documents with a password"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <!-- File list / drop target -->
        <Border Grid.Row="1" BorderBrush="#FFAAAAAA" BorderThickness="1" CornerRadius="4"
                AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver" Background="#FFFAFAFA">
            <Grid>
                <TextBlock Text="Drag files here" Foreground="#FF999999"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasNoFiles}"/>
                <ListBox ItemsSource="{Binding Files}" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Message}" Foreground="#FF888888"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center"
                                           Margin="8,0,4,0" FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Operation + passwords -->
        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Action:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Grid.Column="1" Width="180" ItemsSource="{Binding Operations}"
                          SelectedItem="{Binding Operation}"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#FF888888"
                           Text="Protect = add a new password. Change/Remove need the current password."/>
            </Grid>
            <Grid Margin="0,8,0,0" IsEnabled="{Binding NeedsCurrentPassword}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Current password:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <PasswordBox Grid.Column="1" x:Name="CurrentBox"/>
            </Grid>
            <Grid Margin="0,8,0,0" IsEnabled="{Binding NeedsNewPassword}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="New password:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <PasswordBox Grid.Column="1" x:Name="PasswordBox"/>
                <TextBlock Grid.Column="2" Text="Confirm:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                <PasswordBox Grid.Column="3" x:Name="ConfirmBox"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" Text="{Binding Template, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Tokens: {OriginalName} {Ext} {Date} {DDMMYYYY} {Seq} {DetectedName} {DetectedDate}"/>
            </Grid>
            <CheckBox Margin="0,8,0,0"
                      Content="Overwrite the original file in place (instead of creating a new protected copy)"
                      IsChecked="{Binding Overwrite}"/>
        </StackPanel>

        <!-- Status + buttons -->
        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Add Files…" Click="AddFiles_Click" Padding="10,4" Margin="4,0"/>
                <Button Content="Clear" Click="Clear_Click" Padding="10,4" Margin="4,0"/>
                <Button Content="Preview" Click="Preview_Click" Padding="10,4" Margin="4,0"
                        IsEnabled="{Binding CanRun}"/>
                <Button Content="Apply" Click="Apply_Click" Padding="14,4" Margin="4,0"
                        FontWeight="SemiBold" IsEnabled="{Binding CanRun}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
