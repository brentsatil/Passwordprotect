# Binary deps (qpdf.exe + DLLs, 7z.exe) are bundled in bin/ so the
# standalone PasswordProtect tool works out of the box. Pinned in bin/HASHES.txt.

# Local build / test artefacts
*.tmp
*.bak
tests/fixtures/out/
*.escrow.json

# PowerShell module caches
*.psd1.bak

# .NET build output for the native app (scoped to app/ so the committed
# top-level bin/ with qpdf.exe/7z.exe is never ignored).
app/**/bin/
app/**/obj/
TestResults/
*.user
